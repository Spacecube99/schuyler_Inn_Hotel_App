{
  "expo": {
    "name": "arizmendi_Yaasir_App",
    "slug": "arizmendi_Yaasir_App",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/bed_icon.png",
    "scheme": "arizmendiyaasirapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.yaasirarizmendi.schuylerinn"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/bed_icon.png",
        "backgroundImage": "./assets/images/star_icon.png",
        "monochromeImage": "./assets/images/bed_icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.yaasirarizmendi.schuylerinn"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/bed_icon.png"
    },
    "plugins": [
      "expo-notifications",
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/bed_icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ae4a9d96-f74b-40c3-a137-77c9709dfe17"
      }
    }
  }
}
